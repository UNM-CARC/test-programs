#!/bin/bash -l
#SBATCH --job-name=test-quantumatk
#SBATCH --output=%x-%j.out
#SBATCH --error=%x-%j.err
#SBATCH --partition=debug
#SBATCH --time=00:10:00
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=8
#SBATCH --mem=8G

set -euo pipefail
cd "${SLURM_SUBMIT_DIR:-$PWD}"

module load atk

atkpython electrode_mesh_loop.py
