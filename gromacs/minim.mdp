integrator              = steep
nsteps                  = 10
emtol                   = 1000.0
emstep                  = 0.01

nstlist                 = 10
cutoff-scheme           = Verlet
ns_type                 = grid
coulombtype             = PME
rcoulomb                = 1.2
vdwtype                 = Cut-off
rvdw                    = 1.2

pbc                     = xyz
constraints             = h-bonds
constraint_algorithm    = lincs
