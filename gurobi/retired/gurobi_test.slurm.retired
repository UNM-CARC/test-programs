#!/bin/bash -l
#SBATCH --job-name=test-gurobi
#SBATCH --output=%x-%j.out
#SBATCH --error=%x-%j.err
#SBATCH --partition=debug
#SBATCH --time=00:05:00
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=1
#SBATCH --mem=1G

set -euo pipefail
cd "${SLURM_SUBMIT_DIR:-$PWD}"

module load gurobi
module load r

Rscript linear_program.R
